# Server Environment Variables (for server.js)
# Copy this file to .env in the same directory and fill in your values.
# DO NOT commit .env — it contains secrets.

# ============================================
# PORT
# ============================================
PORT=3002

# ============================================
# SUPABASE — DATABASE + LEGACY AUTH ADMIN
# ============================================
# Get from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# IMPORTANT: Use the SERVICE ROLE key (not the anon key). It has elevated
# permissions and must NEVER reach the browser.
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ============================================
# JWT — APP-SIGNED ACCESS TOKENS
# ============================================
# 64+ random bytes, base64-encoded. Used by jwt.js to sign access tokens
# (HS256). Must match Supabase's JWT secret so RLS policies (auth.uid())
# accept our tokens. Get/rotate from:
#   Supabase dashboard → Settings → API → JWT Settings → JWT Secret
JWT_SECRET=your-supabase-jwt-secret-here
JWT_ACCESS_TTL=900           # 15 min — access token lifetime in seconds
JWT_REFRESH_TTL=2592000      # 30 days — refresh token lifetime in seconds

# ============================================
# BREVO — TRANSACTIONAL EMAIL
# ============================================
# Sends verification, password reset, and account claim emails.
# Get the API key from app.brevo.com → SMTP & API → API keys.
# When BREVO_API_KEY is empty, the server logs the email to console
# instead of sending — useful for local dev without configuring Brevo.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=noreply@akong-online.com
BREVO_SENDER_NAME=Songo

# ============================================
# APP_URL — Frontend base URL
# ============================================
# Used by the server to build links inside emails and to construct the
# OAuth callback target. NO trailing slash.
#   Dev:  http://localhost:3000
#   Prod: https://akong-online.com
#
# Email/auth links built from APP_URL:
#   ${APP_URL}/auth/verify-email?token=...
#   ${APP_URL}/auth/reset-password?token=...
#   ${APP_URL}/auth/claim?token=...
#   ${APP_URL}/auth/oauth/callback?code=...
APP_URL=http://localhost:3000

# ============================================
# GOOGLE OAUTH
# ============================================
# Setup steps (one-time):
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create OAuth 2.0 Client ID (type: "Web application")
#   3. Add Authorized redirect URIs — MUST match GOOGLE_REDIRECT_URI:
#        Dev:  http://localhost:3002/auth/oauth/google/callback
#        Prod: https://api.akong-online.com/auth/oauth/google/callback
#   4. Copy the Client ID + Client Secret below
#   5. Restart the server (Node reads .env once at boot)
#
# When unset, the Google sign-in button responds with HTTP 503
# "google_oauth_not_configured" — the rest of auth still works.
#
# GOOGLE_REDIRECT_URI is the URL Google calls AFTER the user signs in.
# It points to the SERVER (server.js), not the frontend.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3002/auth/oauth/google/callback

# ============================================
# DEGRADED MODES (safe to leave unset)
# ============================================
# - No Supabase: server runs but no DB persistence, no auth, no rooms.
# - No JWT_SECRET: signup/login return 500.
# - No Brevo: emails are logged to console (dev mode).
# - No Google OAuth: button shows but returns 503 on click.
